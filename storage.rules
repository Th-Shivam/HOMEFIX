rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn()
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function underMaxSize(maxBytes) {
      return request.resource.size < maxBytes;
    }

    // Profile avatars — 2 MB max
    match /users/{userId}/avatar.jpg {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId)
        && isImage()
        && underMaxSize(2 * 1024 * 1024);
    }

    match /users/{userId}/avatar.png {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId)
        && isImage()
        && underMaxSize(2 * 1024 * 1024);
    }

    // Service request photos — 5 MB max
    match /service_requests/{requestId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && isImage()
        && underMaxSize(5 * 1024 * 1024);
    }

    // Payment proof uploads — 5 MB max
    match /payments/{userId}/proof_{paymentId}.jpg {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId)
        && isImage()
        && underMaxSize(5 * 1024 * 1024);
    }

    match /payments/{userId}/proof_{paymentId}.png {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId)
        && isImage()
        && underMaxSize(5 * 1024 * 1024);
    }
  }
}
